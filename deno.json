{
  "lock": false,
  "tasks": {
    "lume": "echo \"import 'lume/cli.ts'\" | deno run -A -",
    "build": "deno task lume",
    "serve": "deno task lume -s"
  },
  "compilerOptions": {
    "types": ["lume/types.ts"]
  },
  "importMap": "./import_map.json",
  "exclude": ["./_site"],
  "unstable": ["temporal"],
  "lint": {
    "plugins": ["https://deno.land/x/lume@v3.0.2/lint.ts"]
  }
}